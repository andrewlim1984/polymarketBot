# ===========================================
# Polymarket Scanner Configuration
# ===========================================

# --- Wallet Configuration (Required for trading) ---
# Your Polygon wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Your Polymarket proxy wallet address (funder)
WALLET_ADDRESS=0xYourWalletAddressHere

# Signature type: 0 = EOA, 1 = POLY_PROXY, 2 = GNOSIS_SAFE
SIGNATURE_TYPE=2

# --- RPC Configuration ---
# Polygon RPC URL (default: public endpoint)
RPC_URL=https://polygon-rpc.com

# --- Scanner Settings ---
# How often to scan markets (in milliseconds)
SCAN_INTERVAL_MS=30000

# Minimum spread to flag as opportunity (e.g., 0.02 = 2%)
MIN_SPREAD_THRESHOLD=0.02

# --- Trading Settings ---
# Enable auto-trading (set to "true" to enable, "false" for scan-only mode)
AUTO_TRADE_ENABLED=false

# Maximum USDC to spend per trade
MAX_TRADE_SIZE_USDC=50

# Maximum total exposure across all positions (USDC)
MAX_TOTAL_EXPOSURE_USDC=500

# Daily loss limit (USDC) - bot stops if daily losses exceed this
DAILY_LOSS_LIMIT_USDC=100

# Minimum orderbook depth (USDC) required to consider trading
MIN_LIQUIDITY_USDC=100

# Order type: FOK (Fill-or-Kill) or GTC (Good-Til-Cancelled)
ORDER_TYPE=FOK

# --- Backtest Settings ---
# Data source: "telonex" (tick-level quotes via Telonex.io) or "clob" (Polymarket CLOB API)
# Default: telonex if TELONEX_API_KEY is set, otherwise clob
BACKTEST_SOURCE=telonex

# Telonex API key (required for telonex data source, get one at https://telonex.io)
TELONEX_API_KEY=your_telonex_api_key_here

# Starting capital for backtest simulation (USDC)
BACKTEST_CAPITAL=10000

# Trade size per opportunity in backtest (USDC)
BACKTEST_TRADE_SIZE=100

# Minimum spread threshold for backtest (e.g., 0.02 = 2%)
BACKTEST_MIN_SPREAD=0.02

# Fee rate to simulate (e.g., 0.02 = 2%)
BACKTEST_FEE_RATE=0.02

# Gas cost per transaction (USDC)
BACKTEST_GAS_COST=0.007

# Number of days of historical data to fetch
BACKTEST_LOOKBACK_DAYS=30

# Price history interval: 1h, 6h, 1d, 1w, max
BACKTEST_INTERVAL=1h

# Number of price data points per token (clob source only)
BACKTEST_FIDELITY=500

# Max events to backtest (0 = all available)
BACKTEST_MAX_EVENTS=200

# --- Backtest Risk Constraints ---
# These mirror the live trading risk params so the backtest matches real behavior.
# Set to 0 to disable a constraint.

# Maximum total exposure across all open positions (USDC)
BACKTEST_MAX_EXPOSURE=500

# Daily loss limit (USDC) - stop trading for the day if losses exceed this
BACKTEST_DAILY_LOSS=100

# Minimum orderbook depth (USDC) required to consider a trade (Telonex source only)
BACKTEST_MIN_LIQUIDITY=100

# --- Backtest Latency Simulation ---
# Simulated latency in milliseconds between detecting an opportunity and executing (0 = instant)
BACKTEST_LATENCY_MS=0

# Set to "true" to run 3 latency scenarios (250ms, 500ms, 1000ms) and print a comparison table
BACKTEST_LATENCY_COMPARE=false

# ===========================================
# Whale Copy-Trading Strategy
# ===========================================

# --- Whale Leaderboard Discovery ---
# Number of top wallets to track from the leaderboard
WHALE_TOP_WALLETS=25

# Leaderboard time period: DAY, WEEK, MONTH, ALL
WHALE_LEADERBOARD_PERIOD=WEEK

# Leaderboard category: OVERALL, POLITICS, SPORTS, CRYPTO, etc.
WHALE_LEADERBOARD_CATEGORY=OVERALL

# How often to refresh the leaderboard (ms) — default 1 hour
WHALE_LEADERBOARD_REFRESH_MS=3600000

# --- Whale Trade Monitoring ---
# How often to poll whale trades (ms) — default 15 seconds
WHALE_POLL_MS=15000

# Minimum whale PnL (USDC) to qualify for tracking
WHALE_MIN_PNL=1000

# Maximum age of a whale trade to copy (ms) — skip if older
WHALE_MAX_COPY_DELAY_MS=300000

# --- Copy Trade Sizing ---
# Fraction of whale's trade size to copy (0.1 = 10%)
WHALE_COPY_FRACTION=0.1

# Maximum USDC per copy trade
WHALE_MAX_COPY_SIZE=50

# Minimum confidence score to copy (0-1)
WHALE_MIN_CONFIDENCE=0.3

# --- Wallet Switch Detection ---
# Enable behavioral fingerprinting and fund flow tracking
WHALE_CLUSTER_ENABLED=false

# Similarity threshold for behavioral matching (0-1)
WHALE_CLUSTER_THRESHOLD=0.7

# Days of inactivity before a wallet is considered "switched"
WHALE_INACTIVITY_DAYS=7

# --- Whale Auto-Trading ---
# Enable auto copy-trading ("true" to enable, "false" for monitor-only)
WHALE_AUTO_TRADE=false

# --- Whale Backtest Settings ---
# Starting capital for whale backtest (falls back to BACKTEST_CAPITAL)
WHALE_BT_CAPITAL=10000

# Number of top wallets to simulate copying
WHALE_BT_TOP_WALLETS=25

# Max USDC per copy trade in backtest
WHALE_BT_MAX_COPY_SIZE=50

# Copy size fraction in backtest (0.1 = 10% of whale's trade)
WHALE_BT_COPY_FRACTION=0.1

# Simulated copy delay in ms
WHALE_BT_COPY_DELAY_MS=5000

# Lookback period in days (falls back to BACKTEST_LOOKBACK_DAYS)
WHALE_BT_LOOKBACK_DAYS=14

# Max exposure USDC (falls back to BACKTEST_MAX_EXPOSURE)
WHALE_BT_MAX_EXPOSURE=500

# Daily loss limit USDC (falls back to BACKTEST_DAILY_LOSS)
WHALE_BT_DAILY_LOSS=100
