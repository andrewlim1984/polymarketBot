{
  "name": "polymarket-scanner",
  "version": "1.0.0",
  "description": "Polymarket arbitrage scanner and auto-trading bot",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "scan": "ts-node src/scan-only.ts",
    "backtest": "ts-node src/backtest.ts",
    "whale": "ts-node src/whale-scanner.ts",
    "whale:backtest": "ts-node src/whale-backtest.ts",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "polymarket",
    "arbitrage",
    "trading",
    "scanner",
    "prediction-market"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@dsnp/parquetjs": "^1.8.7",
    "@polymarket/clob-client": "^4.0.0",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "dotenv": "^16.3.0",
    "ethers": "^5.8.0",
    "ws": "^8.16.0"
  }
}
